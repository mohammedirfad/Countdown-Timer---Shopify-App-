{
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
        "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
        "^.+\\.tsx?$": [
            "ts-jest",
            {
                "tsconfig": {
                    "module": "commonjs"
                }
            }
        ]
    },
    "testMatch": [
        "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
        "*.ts",
        "models/*.ts",
        "!**/node_modules/**"
    ]
}